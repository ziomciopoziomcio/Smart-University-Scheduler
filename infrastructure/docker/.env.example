#.env.example

# Database configuration
DB_HOST=postgres
DB_PORT=5432
# Note: DB_USER, DB_PASSWORD, and DB_NAME are used in both backend and PostgreSQL container
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

SECRET_KEY=change-to-a-strong-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...
SMTP_FROM=Smart University Scheduler <no-reply@twojadomena.pl>
PUBLIC_BASE_URL=http://localhost:3000

# Security & CORS Configuration
CORS_ORIGINS=http://localhost:3000
